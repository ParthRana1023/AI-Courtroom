# Server Configuration
PORT=8000
TESTING=False

# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=AI-Courtroom
TEST_MONGODB_DB_NAME=AI-Courtroom-Test

# Security & Authentication
SECRET_KEY=your-secure-random-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
EXTENDED_TOKEN_EXPIRE_DAYS=7

# CORS & Frontend Integration
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://10.0.2.2:3000,capacitor://localhost,ionic://localhost
CORS_ALLOW_ORIGIN_REGEX=

# AI Providers (API Keys)
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Per-Task LLM Configuration (Optional overrides)
# DRAFTER_MODEL=llama-3.3-70b-versatile
# DRAFTER_PROVIDER=groq
# DRAFTER_FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# DRAFTER_FALLBACK_PROVIDER=openrouter

# LAWYER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# LAWYER_PROVIDER=openrouter
# LAWYER_FALLBACK_MODEL=llama-3.3-70b-versatile
# LAWYER_FALLBACK_PROVIDER=groq

# JUDGE_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# JUDGE_PROVIDER=openrouter
# JUDGE_FALLBACK_MODEL=llama-3.3-70b-versatile
# JUDGE_FALLBACK_PROVIDER=groq

# ANALYZER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# ANALYZER_PROVIDER=openrouter
# ANALYZER_FALLBACK_MODEL=llama-3.3-70b-versatile
# ANALYZER_FALLBACK_PROVIDER=groq

# PARTY_MODEL=llama-3.3-70b-versatile
# PARTY_PROVIDER=groq
# PARTY_FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# PARTY_FALLBACK_PROVIDER=openrouter

# WITNESS_MODEL=llama-3.3-70b-versatile
# WITNESS_PROVIDER=groq
# WITNESS_FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# WITNESS_FALLBACK_PROVIDER=openrouter

# Unused/Legacy model config
llm_model=meta-llama/llama-4-scout-17b-16e-instruct

# RAG & Local Embeddings
RAG_ENABLED=True
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
RAG_TOP_K=8
RAG_MIN_SCORE=0.25

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_STATE_SECRET=another-secret
RISC_WEBHOOK_SECRET=
OAUTH_STATE_TOKEN_EXPIRY=600

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# Cloudflare (Evidence Image Generation)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
EVIDENCE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
EVIDENCE_IMAGE_FALLBACK_MODEL=@cf/black-forest-labs/flux-2-dev
EVIDENCE_IMAGE_GENERATION_LIMIT_PER_CASE=2
EVIDENCE_IMAGE_GENERATION_TIMEOUT_SECONDS=120

# Email SMTP Service
email_sender=noreply@example.com
email_username=
email_password=
smtp_server=smtp.gmail.com
smtp_port=587

# GeoLocation API
CSC_API_KEY=

# Rate Limiting
CASE_GENERATION_RATE_LIMIT=5
CASE_GENERATION_RATE_WINDOW=86400
ARGUMENT_RATE_LIMIT=10
ARGUMENT_RATE_WINDOW=86400

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
