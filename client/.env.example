# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth
# Must be NEXT_PUBLIC_ prefixed so it is exposed to the browser
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Diagnostics & Remote Logging
NEXT_PUBLIC_LOG_REMOTE_ENABLED=false

# Mobile Build (Capacitor)
CAPACITOR_BUILD=false
CAP_SERVER_URL=http://localhost:3000
